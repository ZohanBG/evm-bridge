# Database (PostgreSQL — use docker-compose up to start)
DATABASE_URL="postgresql://postgres:password@localhost:5432/bridge_db?schema=public"

# Chain A (origin chain — holds GenericToken KLS)
CHAIN_A_ID=31337
CHAIN_A_RPC_URL=http://127.0.0.1:8545
BRIDGE_A=0x_DEPLOYED_BRIDGE_A_ADDRESS
GENERIC_TOKEN_A=0x_DEPLOYED_TOKEN_A_ADDRESS
START_BLOCK_A=0

# Chain B
CHAIN_B_ID=31338
CHAIN_B_RPC_URL=http://127.0.0.1:8546
BRIDGE_B=0x_DEPLOYED_BRIDGE_B_ADDRESS
WRAPPED_TOKEN_B=0x_DEPLOYED_WRAPPED_TOKEN_B_ADDRESS
START_BLOCK_B=0

# Chain C
CHAIN_C_ID=31339
CHAIN_C_RPC_URL=http://127.0.0.1:8547
BRIDGE_C=0x_DEPLOYED_BRIDGE_C_ADDRESS
WRAPPED_TOKEN_C=0x_DEPLOYED_WRAPPED_TOKEN_C_ADDRESS
START_BLOCK_C=0

# Indexer settings
INDEXER_POLL_INTERVAL=5000

# Validator private key (Anvil account #9 for local dev — NEVER use real keys in production)
VALIDATOR_PRIVATE_KEY=0x_YOUR_VALIDATOR_PRIVATE_KEY

# API settings
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001
