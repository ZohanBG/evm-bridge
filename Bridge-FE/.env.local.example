# Copy this file to .env.local and fill in the addresses from `make deploy-local-all`

NEXT_PUBLIC_CHAIN_A_ID=31337
NEXT_PUBLIC_CHAIN_A_RPC=http://127.0.0.1:8545
NEXT_PUBLIC_CHAIN_A_NAME="Chain A"

NEXT_PUBLIC_CHAIN_B_ID=31338
NEXT_PUBLIC_CHAIN_B_RPC=http://127.0.0.1:8546
NEXT_PUBLIC_CHAIN_B_NAME="Chain B"

NEXT_PUBLIC_CHAIN_C_ID=31339
NEXT_PUBLIC_CHAIN_C_RPC=http://127.0.0.1:8547
NEXT_PUBLIC_CHAIN_C_NAME="Chain C"

# Bridge contract addresses (from deploy output)
NEXT_PUBLIC_BRIDGE_A=
NEXT_PUBLIC_BRIDGE_B=
NEXT_PUBLIC_BRIDGE_C=

# Token addresses
NEXT_PUBLIC_GENERIC_TOKEN_A=
NEXT_PUBLIC_WRAPPED_TOKEN_B=
NEXT_PUBLIC_WRAPPED_TOKEN_C=

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:3000

# WalletConnect project ID (get from cloud.walletconnect.com — free tier works)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
