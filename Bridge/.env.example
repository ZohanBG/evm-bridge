DEST_RPC_URL=https://...             # Destination RPC URL
DEST_ETHERSCAN_API_KEY=YOUR_KEY      # Destination explorer API key

OWNER=0x...                          # Deployer/owner address
PRIVATE_KEY=0x...                    # Deployer private key (hex 0x...)

PUBLIC_GENERIC_TOKEN_A_ADDRESS=0x... # Generic token (source) address

BRIDGE_A=0x...                       # Bridge A (source) contract address
GENERIC_TOKEN_A=0x...                # Generic token A address (same as above)

BRIDGE_B=0x...                       # Bridge B (destination) contract address
WRAPPED_TOKEN_B=0x...                # Wrapped token on destination

